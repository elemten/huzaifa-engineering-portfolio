# Optional public GitHub activity username.
VITE_GITHUB_USERNAME=elemten

# Optional map proxy used by the experimental map component.
VITE_FRONTEND_FORGE_API_URL=
VITE_FRONTEND_FORGE_API_KEY=

# Server-only key for the small interactive gift demo.
GROQ_API_KEY=

# Server-only Spotify credentials for the listening card.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REFRESH_TOKEN=

# Never prefix server credentials with VITE_; Vite exposes those values to the browser.
